{
  "name": "design-center",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "npm run generate:projects && vite",
    "generate:projects": "node scripts/generate-project-pages.mjs",
    "clean:generated": "node -e \"import('node:fs/promises').then(fs => fs.rm('.generated',{recursive:true,force:true}))\"",
    "build": "npm run generate:projects && tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
